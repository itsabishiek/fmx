# FMX — environment variables for Supabase + Google sign-in.
# Copy this file to `.env` (gitignored) and fill in the real values.
# These EXPO_PUBLIC_* vars are inlined into the JS bundle at build time. The
# Supabase anon key is public-safe — access is enforced by row-level security.
#
# For EAS builds, mirror these into eas.json -> build.<profile>.env
# (placeholders are already there) or set them as EAS environment variables.

# Supabase project (Dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# WEB client id — used as the audience for the native idToken (required on Android too),
# and entered in Supabase → Auth → Providers → Google.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
# iOS client id — only needed when building for iOS.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
